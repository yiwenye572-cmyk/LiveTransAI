DOUBAO_API_KEY=your-api-key
DOUBAO_RESOURCE_ID=volc.service_type.10053
DOUBAO_AST_WS_URL=wss://openspeech.bytedance.com/api/v4/ast/v2/translate

AST_MODE=s2s
SOURCE_LANGUAGE=en
TARGET_LANGUAGE=zh

# Optional S2S voice when target is zh/en (omit for voice-clone mode)
# AST_SPEAKER_ID=zh_female_vv_uranus_bigtts
# AST_TARGET_AUDIO_FORMAT=ogg_opus
# AST_TARGET_AUDIO_RATE=24000

# Some Windows loopback devices capture at extremely low volume; auto-gain fixes AST AudioMuted.
# LOOPBACK_AUTO_GAIN=1
# LOOPBACK_GAIN_TARGET_PEAK=8000
# LOOPBACK_GAIN_MAX=300
# LOOPBACK_GAIN_MIN_PEAK=500

# Optional: DeepSeek official API for async translation correction
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
